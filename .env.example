# いなチャレ予約管理アプリ 環境変数テンプレート
# このファイルを .env にコピーし、値を設定してください
# .env は .gitignore 対象なのでコミットされません

# Flask セッション暗号化キー（必須）
# 本番では `python -c "import secrets; print(secrets.token_hex(32))"` で生成した値を使用
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# データベース接続URL（省略時は instance/inachalle.db を使用）
# 例: postgresql://user:pass@localhost:5432/inachalle
# DATABASE_URL=

# Flask 動作モード: development / production / testing
# 省略時は production（安全側）
# FLASK_ENV=development

# 開発時のサーバーバインド（省略時は 127.0.0.1:5000）
# FLASK_RUN_HOST=0.0.0.0
# FLASK_RUN_PORT=5000
